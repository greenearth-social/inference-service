########## Common Variables ##########

# Environment
export GE_ENVIRONMENT=local

# GCP Configuration
export GE_GCP_PROJECT_ID=greenearth-471522
export GE_GCP_REGION=us-east1

# Domain mapping / DNS configuration (stage/prod)
export GE_ENABLE_INFERENCE_DOMAIN_MAPPING=true
# Defaults by environment if unset:
#   stage -> inference-stage.greenearth.social
#   prod  -> inference.greenearth.social
export GE_INFERENCE_DOMAIN=

########## Inference Service Variables ##########
# Model registry — configure which models to load (user-tower, post-tower, and/or ranker)
export GE_INFERENCE_MODELS="user-tower,post-tower"

# Two tower manifest — GCS URI or local path to two_tower_serving_manifest.json produced by the
# engagement-prediction training pipeline. Contains model artifact URIs and ClearML model IDs
# for both towers; replaces per-model GE_INFERENCE_*_MODEL_URI / CLEARML_MODEL_ID vars.
export GE_INFERENCE_TWO_TOWER_MANIFEST_URI='gs://greenearth-471522-engagement-prediction-test/Engagement Prediction/.../artifacts/two_tower_serving_manifest/two_tower_serving_manifest.json'
export GE_INFERENCE_TWO_TOWER_AUTHOR_MAP_URI='gs://greenearth-471522-engagement-prediction-test/Engagement Prediction/.../artifacts/author_idx_mapping/author_idx_20260530_153821_decbd26b.parquet'

# Ranker manifest and author map. Required when GE_INFERENCE_MODELS includes ranker.
# export GE_INFERENCE_RANKER_MANIFEST_URI='gs://greenearth-471522-engagement-prediction-test/.../artifacts/ranker_serving_manifest/ranker_serving_manifest.json'
# export GE_INFERENCE_RANKER_AUTHOR_MAP_URI='gs://greenearth-471522-engagement-prediction-test/.../artifacts/author_idx_mapping/author_idx.parquet'

# Inference service runtime configuration
export GE_INFERENCE_MAX_BATCH=1024
export GE_INFERENCE_PREFER_CUDA=1
export GE_INFERENCE_WARMUP=1
# Set this if you know the embedding dimension D in advance; used for input validation and warmup inputs.
export GE_INFERENCE_CONTENT_EMBED_DIM=384
# Required when GE_INFERENCE_MODELS includes user-tower.
export GE_INFERENCE_TWO_TOWER_MAX_HISTORY_LEN=128
# Required when GE_INFERENCE_MODELS includes ranker.
# export GE_INFERENCE_RANKER_MAX_HISTORY_LEN=128

# Optional cache location inside container when downloading gs:// model artifacts
export GE_INFERENCE_MODEL_CACHE_DIR=/tmp/model_cache
