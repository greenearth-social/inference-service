########## Common Variables ##########

# Environment
export GE_ENVIRONMENT=local

# GCP Configuration
export GE_GCP_PROJECT_ID=greenearth-471522
export GE_GCP_REGION=us-east1

# Domain mapping / DNS configuration (stage/prod)
export GE_ENABLE_INFERENCE_DOMAIN_MAPPING=true
# Defaults by environment if unset:
#   stage -> inference-stage.greenearth.social
#   prod  -> inference.greenearth.social
export GE_INFERENCE_DOMAIN=

########## Inference Service Variables ##########
# Model registry — configure which models to load (user-tower and/or post-tower)
export GE_INFERENCE_MODELS="user-tower,post-tower"

# Manifest — GCS URI or local path to two_tower_serving_manifest.json produced by the
# engagement-prediction training pipeline. Contains model artifact URIs and ClearML model IDs
# for both towers; replaces per-model GE_INFERENCE_*_MODEL_URI / CLEARML_MODEL_ID vars.
export GE_INFERENCE_MANIFEST_URI='gs://greenearth-471522-engagement-prediction-test/Engagement Prediction/get_data_to_evaluate_two-tower.f45d584d647d406998e5833a79af5643/artifacts/two_tower_serving_manifest/two_tower_serving_manifest.json'
export GE_INFERENCE_AUTHOR_MAP_URI='gs://greenearth-471522-engagement-prediction-test/Engagement Prediction/get_data_to_evaluate_two-tower.f45d584d647d406998e5833a79af5643/artifacts/author_idx_mapping/author_idx_20260530_153821_decbd26b.parquet'

# Inference service runtime configuration
export GE_INFERENCE_MAX_BATCH=1024
export GE_INFERENCE_PREFER_CUDA=1
export GE_INFERENCE_WARMUP=1
# Set this if you know the embedding dimension D in advance; used for input validation and warmup inputs.
export GE_INFERENCE_EMBED_DIM=384
# Required: all user histories shorter than this length should be zero-padded to this length.
export GE_INFERENCE_MAX_HISTORY_LEN=128

# Optional cache location inside container when downloading gs:// model artifacts
export GE_INFERENCE_MODEL_CACHE_DIR=/tmp/model_cache
